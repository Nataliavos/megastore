      "name": "🔄 Migrate",
      "item": [
        {
          "name": "Cargar CSV completo",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/migrate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "migrate"
              ]
            },
            "description": "Carga masiva del CSV hacia PostgreSQL. Idempotente: se puede ejecutar varias veces sin duplicar datos."
          },
          "response": []
        }
      ]
    },
    {
