            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_sku\": \"KBD-LOG-001\",\n  \"product_name\": \"Teclado Logitech K120\",\n  \"unit_price\": 85000,\n  \"quantity\": 20,\n  \"category_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products"
              ]
            }
          },
          "response": []
        },
        {
          "name": "PUT actualizar producto",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_name\": \"Teclado Logitech K120 Actualizado\",\n  \"unit_price\": 90000,\n  \"quantity\": 15,\n  \"category_id\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/products/{{product-id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{product-id}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "DELETE eliminar producto (log en MongoDB)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{product-id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "products",
                "{{product-id}}"
              ]
            },
            "description": "Elimina el producto de PostgreSQL y guarda un snapshot en MongoDB (audit_logs)."
          },
          "response": []
        }
      ]
    },
